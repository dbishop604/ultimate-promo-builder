{
  "functions": {
    "api/access.js": {
      "maxDuration": 60
    },
    "api/builder.js": {
      "includeFiles": "private/**",
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/app",
      "destination": "/api/builder"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    }
  ]
}
